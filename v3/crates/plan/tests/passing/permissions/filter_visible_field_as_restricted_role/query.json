{
  "version": "v1",
  "queries": {
    "albums": {
      "model": {
        "subgraph": "default",
        "modelName": "Album",
        "limit": 5,
        "filter": {
          "comparison": {
            "operand": { "field": { "fieldName": "Title" } },
            "operator": "_eq",
            "argument": { "literal": "Let There Be Rock" }
          }
        },
        "selection": {
          "album_id": {
            "field": {
              "fieldName": "AlbumId"
            }
          },
          "album_title": {
            "field": {
              "fieldName": "Title"
            }
          }
        }
      }
    }
  }
}
