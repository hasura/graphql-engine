{
  "version": "v1",
  "queries": {
    "albums": {
      "model": {
        "subgraph": "default",
        "modelName": "Album",
        "limit": 5,
        "filter": {
          "exists": {
            "field_name": "ArtistId",
            "predicate": {
              "comparison": {
                "operand": { "field": { "fieldName": "AlbumId" } },
                "operator": "_eq",
                "argument": { "literal": 1 }
              }
            }
          }
        },
        "selection": {
          "album_id": {
            "field": {
              "fieldName": "AlbumId"
            }
          }
        }
      }
    }
  }
}
